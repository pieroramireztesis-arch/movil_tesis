<?xml version="1.0" encoding="utf-8"?>
<!--
   Reglas de backup para Android ≤ 11 (API ≤ 30).
   Excluye las SharedPreferences de sesión para que el JWT
   no quede guardado en copias de seguridad de Google.
-->
<full-backup-content>
    <!-- ✅ Excluir credenciales de sesión del backup -->
    <exclude domain="sharedpref" path="auth_prefs.xml"/>
</full-backup-content>