<?xml version="1.0" encoding="utf-8"?>
<!--
   Reglas de extracción de datos para Android 12+ (API 31+).
   Excluye las SharedPreferences de sesión para que el JWT
   no quede guardado en backups en la nube ni transferencias de dispositivo.
   Ver: https://developer.android.com/about/versions/12/backup-restore
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- ✅ No respaldar el token JWT ni datos de sesión en la nube -->
        <exclude domain="sharedpref" path="auth_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- ✅ No transferir el token JWT a otro dispositivo -->
        <exclude domain="sharedpref" path="auth_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>