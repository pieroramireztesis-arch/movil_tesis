<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ════════════════════════════════════════════════════════════
         TEMA DE MARCA TutorMath · I.E. 27 de Diciembre
         Material 3 CLARO (Light, no DayNight): la app no soporta modo
         oscuro real, así que se fuerza claro para evitar la mezcla de
         fondos blancos hardcodeados con componentes oscuros.
         ════════════════════════════════════════════════════════════ -->
    <style name="Base.Theme.Aplicacion_Tesis" parent="Theme.Material3.Light.NoActionBar">
        <!-- Marca: azul educativo -->
        <item name="colorPrimary">@color/ai_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/ai_primary_light</item>
        <item name="colorOnPrimaryContainer">@color/ai_primary_dark</item>

        <item name="colorSecondary">@color/ai_comp2</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">#E6F4EA</item>
        <item name="colorOnSecondaryContainer">@color/ai_comp2</item>

        <!-- Superficies y fondo -->
        <item name="android:colorBackground">@color/ai_bg_screen</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/ai_text_dark</item>
        <item name="colorSurfaceVariant">@color/ai_primary_light</item>
        <item name="colorOnSurfaceVariant">@color/ai_text_dark</item>
        <item name="colorOutline">@color/ai_border</item>
        <item name="colorOutlineVariant">@color/ai_divider</item>
        <item name="colorError">@color/ai_error</item>

        <!-- Tipografía global: Nunito (redondeada, amigable para escolares) -->
        <item name="android:fontFamily">@font/nunito</item>
        <item name="fontFamily">@font/nunito</item>

        <!-- Esquinas redondeadas consistentes en componentes M3 -->
        <item name="shapeAppearanceCornerSmall">@style/Shape.TutorMath.Small</item>
        <item name="shapeAppearanceCornerMedium">@style/Shape.TutorMath.Medium</item>
        <item name="shapeAppearanceCornerLarge">@style/Shape.TutorMath.Large</item>

        <!-- Cards con borde visible -->
        <item name="materialCardViewStyle">@style/Widget.TutorMath.Card</item>

        <!-- Barra de estado azul (coincide con el header de marca) -->
        <item name="android:statusBarColor">@color/ai_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <style name="Theme.Aplicacion_Tesis" parent="Base.Theme.Aplicacion_Tesis" />

    <!-- ── Formas ─────────────────────────────────────────────────── -->
    <style name="Shape.TutorMath.Small" parent="ShapeAppearance.Material3.Corner.Small">
        <item name="cornerSize">@dimen/radius_small</item>
    </style>
    <style name="Shape.TutorMath.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">@dimen/radius_card</item>
    </style>
    <style name="Shape.TutorMath.Large" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSize">@dimen/radius_large</item>
    </style>

    <!-- ════════════════════════════════════════════════════════════
         ESCALA TIPOGRÁFICA TutorMath (única fuente de verdad)
         Display 28 · H1 22 · H2 18 · Subtitle 16 · Body 15 ·
         Caption 13 · Label 12 — no usar tamaños fuera de esta escala.
         ════════════════════════════════════════════════════════════ -->
    <style name="TextAppearance.TutorMath.Display" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ai_text_dark</item>
    </style>
    <style name="TextAppearance.TutorMath.H1" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ai_text_dark</item>
    </style>
    <style name="TextAppearance.TutorMath.H2" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ai_text_dark</item>
    </style>
    <style name="TextAppearance.TutorMath.Subtitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ai_text_dark</item>
    </style>
    <style name="TextAppearance.TutorMath.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/ai_text_dark</item>
    </style>
    <style name="TextAppearance.TutorMath.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/ai_text_muted</item>
    </style>
    <style name="TextAppearance.TutorMath.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/ai_text_muted</item>
    </style>

    <!-- Tabs (legacy, por si queda algún TabLayout) -->
    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">12sp</item>
        <item name="android:maxLines">1</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- ── MaterialCardView global — borde + sombra suave ───────── -->
    <style name="Widget.TutorMath.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="strokeColor">@color/ai_card_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">@dimen/radius_card</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <!-- ── Bottom Navigation TutorMath (estudiante y docente) ────── -->
    <style name="Widget.TutorMath.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.TutorMath.BottomNav.Indicator</item>
        <item name="android:background">@color/white</item>
        <item name="elevation">8dp</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>
    <style name="Widget.TutorMath.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/ai_primary_light</item>
    </style>

</resources>