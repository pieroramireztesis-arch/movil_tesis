<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fondo blanco -->
    <solid android:color="#1E293B" />

    <!-- Bordecito gris clarito -->
    <stroke
        android:width="1dp"
        android:color="#DDDDDD" />

    <!-- Bordes redondeados -->
    <corners android:radius="16dp" />

    <!-- Padding interno opcional -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />
</shape>
