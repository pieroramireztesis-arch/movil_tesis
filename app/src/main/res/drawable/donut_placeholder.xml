<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- anillo gris de fondo -->
    <item>
        <shape android:shape="oval">
            <size android:width="220dp" android:height="220dp"/>
            <stroke android:width="18dp" android:color="@color/ai_progress_track"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
    <!-- anillo azul por “progreso” (decorativo) -->
    <item android:top="0dp" android:bottom="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="oval">
            <size android:width="220dp" android:height="220dp"/>
            <stroke android:width="18dp" android:color="@color/ai_primary"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
    <!-- círculo interior blanco -->
    <item android:top="35dp" android:bottom="35dp" android:left="35dp" android:right="35dp">
        <shape android:shape="oval">
            <solid android:color="#1E293B"/>
        </shape>
    </item>
</layer-list>
