<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla de arranque (splash): escudo de la I.E. 27 de Diciembre centrado
     sobre el navy de marca. Se muestra como windowBackground de LoginActivity
     ANTES de que cargue cualquier código → arranque instantáneo y profesional.
     (width/height en items de layer-list requieren API 23+; minSdk es 24.) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fondo navy de marca (mismo ai_bg_screen del tema) -->
    <item android:drawable="@color/ai_bg_screen" />

    <!-- Escudo del colegio centrado -->
    <item
        android:width="240dp"
        android:height="240dp"
        android:gravity="center"
        android:drawable="@drawable/ic_launcher_foreground" />

</layer-list>