<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_arrow_back_24"
                app:tint="@color/ai_text_dark"
                android:contentDescription="@string/back" />

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Reporte de Estudiante"
                android:textColor="@color/ai_text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- CARD CABECERA ESTUDIANTE -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvStudentAvatar"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:gravity="center"
                    android:text="AP"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:background="@drawable/bg_circle_primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="14dp">

                    <TextView
                        android:id="@+id/tvStudentName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alumno Prueba"
                        android:textColor="@color/ai_text_dark"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStudentSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Progreso general: 0%"
                        android:textColor="@color/ai_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD PROGRESO GENERAL — LineChart con datos reales -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Evolución de Progreso"
                    android:textColor="@color/ai_text_dark"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="% de respuestas correctas por hora"
                    android:textColor="@color/ai_text_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <!-- Título eje Y -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ % Correcto"
                    android:textSize="13sp"
                    android:textColor="@color/ai_text_muted"
                    android:layout_marginBottom="2dp"/>

                <!-- LineChart -->
                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartProgressGeneral"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="4dp" />

                <!-- Título eje X -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fecha / Hora →"
                    android:textSize="13sp"
                    android:textColor="@color/ai_text_muted"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD RADAR COMPETENCIAS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Desempeño por Competencia"
                    android:textColor="@color/ai_text_dark"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nivel de dominio en cada competencia MINEDU"
                    android:textColor="@color/ai_text_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <com.github.mikephil.charting.charts.RadarChart
                    android:id="@+id/chartCompetencias"
                    android:layout_width="match_parent"
                    android:layout_height="260dp" />

                <!-- Leyenda manual -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:background="#0A6FD4" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Cantidad"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/ai_primary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:background="#27AE60" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Regularidad"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/ai_comp2" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:background="#E67E22" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Forma"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#E67E22" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <View
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:background="#7B1FA2" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="Datos"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#7B1FA2" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ CARD MATERIALES DE ESTUDIO ══════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMaterialesEstudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚 Materiales de Estudio"
                    android:textColor="@color/ai_text_dark"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Revisiones de recursos asignados"
                    android:textColor="@color/ai_text_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="10dp" />

                <!-- 3 chips de resumen -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="12dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@color/ai_primary_light"
                        android:padding="10dp" android:layout_marginEnd="4dp">
                        <TextView android:id="@+id/tvMatTotalRevisiones"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/ai_comp4"
                            android:textSize="24sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Revisiones" android:textColor="@color/ai_text_dark"
                            android:textSize="13sp" android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@color/ai_primary_light"
                        android:padding="10dp" android:layout_marginEnd="4dp">
                        <TextView android:id="@+id/tvMatTiempoTotal"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0 min" android:textColor="@color/ai_primary"
                            android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tiempo total" android:textColor="@color/ai_text_dark"
                            android:textSize="13sp" android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@color/ai_primary_light"
                        android:padding="10dp">
                        <TextView android:id="@+id/tvMatDistintos"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/ai_comp2"
                            android:textSize="24sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Materiales" android:textColor="@color/ai_text_dark"
                            android:textSize="13sp" android:gravity="center"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- BarChart horizontal — top materiales -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Revisiones por material"
                    android:textColor="@color/ai_text_muted"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <com.github.mikephil.charting.charts.HorizontalBarChart
                    android:id="@+id/chartMatRevisiones"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="2dp" />

                <!-- Empty state -->
                <TextView
                    android:id="@+id/tvMatEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Este estudiante aún no ha revisado materiales de estudio."
                    android:textColor="@color/ai_text_muted"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="16dp"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!-- ══ FIN CARD MATERIALES ════════════════════════════════════ -->

        <!-- ══ CARD TIEMPO POR DIFICULTAD ══════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTiempoNivelDocente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱ Tiempo por Dificultad"
                    android:textColor="@color/ai_text_dark"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiempo promedio de respuesta y tasa de acierto por nivel"
                    android:textColor="@color/ai_text_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <!-- Cabecera de columnas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2" android:text="Nivel"
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/ai_text_muted"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1.5" android:text="Tiempo prom."
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/ai_text_muted" android:gravity="center"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Aciertos"
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/ai_text_muted" android:gravity="end"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Resp."
                        android:textSize="13sp" android:textStyle="bold"
                        android:textColor="@color/ai_text_muted" android:gravity="end"/>
                </LinearLayout>

                <!-- Filas dinámicas -->
                <LinearLayout
                    android:id="@+id/llTiempoNivelDocente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <TextView
                    android:id="@+id/tvTiempoNivelDocenteEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aún no hay respuestas registradas."
                    android:textColor="@color/ai_text_muted"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="16dp"
                    android:visibility="gone"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!-- ══ FIN CARD TIEMPO POR DIFICULTAD ══════════════════════════ -->

        <!-- CARD FRECUENCIA DE USO -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFrecuenciaIndividual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardUseCompatPadding="true"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱 Uso de la Aplicación"
                    android:textColor="@color/ai_text_dark"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Interacciones totales del estudiante"
                    android:textColor="@color/ai_text_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="10dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal" android:background="@color/ai_primary_light" android:padding="12dp" android:layout_marginEnd="4dp">
                        <TextView android:id="@+id/tvReportFrecEjercicios" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/ai_primary" android:textSize="28sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ejercicios" android:textColor="@color/ai_text_dark" android:textSize="12sp" android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal" android:background="@color/ai_primary_light" android:padding="12dp" android:layout_marginEnd="4dp">
                        <TextView android:id="@+id/tvReportFrecMateriales" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/ai_comp2" android:textSize="28sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Materiales" android:textColor="@color/ai_text_dark" android:textSize="12sp" android:gravity="center"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal" android:background="@color/ai_primary_light" android:padding="12dp">
                        <TextView android:id="@+id/tvReportFrecTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/ai_comp3" android:textSize="28sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total" android:textColor="@color/ai_text_dark" android:textSize="12sp" android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvReportFrecUltima"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Última actividad: --"
                    android:textColor="@color/ai_text_dark"
                    android:textSize="13sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>