<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- SECCIÓN AZUL: logo + nombre app + colegio -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="230dp"
        android:background="@color/ai_primary"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="24dp">

        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:padding="10dp"
            android:background="@drawable/bg_white_circle">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:src="@drawable/logo_colegio"
                android:contentDescription="Logo I.E. 27 de Diciembre"/>
        </FrameLayout>

        <TextView
            android:layout_marginTop="14dp"
            android:text="TutorMath"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="26sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:layout_marginTop="3dp"
            android:text="I.E. 27 de Diciembre · Lambayeque"
            android:textColor="@color/ai_primary_light"
            android:textSize="13sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- SECCIÓN BLANCA: formulario con esquinas superiores redondeadas -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_form_top_rounded"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Bienvenido de nuevo"
                android:textColor="@color/ai_text_dark"
                android:textStyle="bold"
                android:textSize="18sp"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="¡Vamos a aprender álgebra!"
                android:textColor="@color/ai_text_muted"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Label usuario -->
            <TextView
                android:layout_marginBottom="6dp"
                android:text="Nombre de usuario o correo"
                android:textColor="@color/ai_text_dark"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCorreo"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_person_24"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCorreo"
                    android:hint="usuario o correo@ejemplo.com"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/ai_text_dark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Label contraseña -->
            <TextView
                android:layout_marginBottom="6dp"
                android:text="Contraseña"
                android:textColor="@color/ai_text_dark"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_lock_24"
                app:endIconMode="password_toggle"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:hint="Ingresa tu contraseña"
                    android:inputType="textPassword"
                    android:textColor="@color/ai_text_dark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Olvidé contraseña (alineado derecha) -->
            <TextView
                android:id="@+id/tvOlvide"
                android:layout_marginBottom="20dp"
                android:text="¿Olvidaste tu contraseña?"
                android:textColor="@color/ai_primary"
                android:textStyle="bold"
                android:textSize="13sp"
                android:gravity="end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Botón Iniciar Sesión -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Iniciar Sesión"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/ai_primary"
                android:textColor="@android:color/white"/>

            <!-- Registro -->
            <TextView
                android:id="@+id/tvRegistro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿No tienes cuenta? Regístrate aquí"
                android:textColor="@color/ai_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center_horizontal"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"/>

            <Space android:layout_width="0dp" android:layout_height="16dp"/>
        </LinearLayout>
    </ScrollView>

</LinearLayout>