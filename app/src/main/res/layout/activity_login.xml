<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- HEADER GRADIENTE con orbes decorativos -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@drawable/bg_gradient_header">

        <!-- Orbe decorativo grande — esquina superior derecha -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/bg_orb_white"
            android:layout_gravity="top|end"
            android:layout_marginTop="-60dp"
            android:layout_marginEnd="-60dp"/>

        <!-- Orbe decorativo pequeño — esquina inferior izquierda -->
        <View
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:background="@drawable/bg_orb_white"
            android:layout_gravity="bottom|start"
            android:layout_marginBottom="-20dp"
            android:layout_marginStart="-20dp"/>

        <!-- Orbe medio — centro izquierda -->
        <View
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_orb_white"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="20dp"
            android:layout_marginTop="-40dp"/>

        <!-- Contenido centrado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="28dp">

            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:padding="10dp"
                android:background="@drawable/bg_white_circle">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:src="@drawable/logo_colegio"
                    android:contentDescription="Logo I.E. 27 de Diciembre"/>
            </FrameLayout>

            <TextView
                android:layout_marginTop="12dp"
                android:text="TutorMath"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="28sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_marginTop="3dp"
                android:text="I.E. 27 de Diciembre · Lambayeque"
                android:textColor="@color/ai_primary_light"
                android:textSize="13sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </FrameLayout>

    <!-- FORMULARIO: tarjeta blanca con esquinas superiores redondeadas -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_form_top_rounded"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Bienvenido de nuevo"
                android:textColor="@color/ai_text_dark"
                android:textStyle="bold"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_marginTop="4dp"
                android:layout_marginBottom="28dp"
                android:text="¡Vamos a aprender álgebra!"
                android:textColor="@color/ai_text_muted"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_marginBottom="6dp"
                android:text="Nombre de usuario o correo"
                android:textColor="@color/ai_text_dark"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCorreo"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_person_24"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCorreo"
                    android:hint="usuario o correo@ejemplo.com"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/ai_text_dark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_marginBottom="6dp"
                android:text="Contraseña"
                android:textColor="@color/ai_text_dark"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="6dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_lock_24"
                app:endIconMode="password_toggle"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:hint="Ingresa tu contraseña"
                    android:inputType="textPassword"
                    android:textColor="@color/ai_text_dark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tvOlvide"
                android:layout_marginBottom="20dp"
                android:text="¿Olvidaste tu contraseña?"
                android:textColor="@color/ai_primary"
                android:textStyle="bold"
                android:textSize="13sp"
                android:gravity="end"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Iniciar Sesión"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="14dp"
                app:backgroundTint="@color/ai_primary"
                android:textColor="@android:color/white"/>

            <TextView
                android:id="@+id/tvRegistro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿No tienes cuenta? Regístrate aquí"
                android:textColor="@color/ai_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center_horizontal"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"/>

            <Space android:layout_width="0dp" android:layout_height="16dp"/>
        </LinearLayout>
    </ScrollView>

</LinearLayout>