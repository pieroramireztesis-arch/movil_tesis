<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_bg_screen">

    <!-- Símbolos matemáticos decorativos -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="∑"
        android:textColor="#30FFFFFF"
        android:textSize="72sp"
        android:textStyle="bold"
        android:layout_gravity="top|start"
        android:layout_marginTop="32dp"
        android:layout_marginStart="12dp"
        android:importantForAccessibility="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="π"
        android:textColor="#28FFFFFF"
        android:textSize="56sp"
        android:textStyle="bold"
        android:layout_gravity="top|end"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="16dp"
        android:importantForAccessibility="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="≠"
        android:textColor="#22FFFFFF"
        android:textSize="44sp"
        android:textStyle="bold"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="60dp"
        android:layout_marginStart="20dp"
        android:importantForAccessibility="no"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ═══════════════════════════════════════════
                 CARD 1 — Progreso General
                 Circular = % (regla del profesor)
                 ═══════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/ai_card_bg"
                app:strokeColor="@color/ai_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mi Progreso"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/ai_text_dark"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"/>

                    <!-- Donut circular — % general -->
                    <FrameLayout
                        android:layout_width="152dp"
                        android:layout_height="152dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="8dp">

                        <com.example.aplicacion_tesis.ui.components.DonutChartView
                            android:id="@+id/donutGeneral"
                            android:layout_width="152dp"
                            android:layout_height="152dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_gravity="center">

                            <TextView
                                android:id="@+id/tvPctGeneral"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="@color/ai_primary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="objetivo"
                                android:textSize="10sp"
                                android:textColor="@color/ai_text_muted"/>
                        </LinearLayout>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvNivelGeneral"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠ Inicio"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ai_warning"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvMensajeMotivacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¡Sigue así, vas por buen camino!"
                        android:textSize="13sp"
                        android:textColor="@color/ai_text_muted"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"/>

                    <!-- Divisor -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/ai_divider"
                        android:layout_marginBottom="12dp"/>

                    <!-- Stats: ejercicios + materiales (cantidades en texto) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:background="@color/ai_primary_light"
                            android:padding="10dp"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:id="@+id/tvStatEjercicios"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/ai_primary"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ejercicios"
                                android:textSize="11sp"
                                android:textColor="@color/ai_text_muted"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:background="@color/ai_primary_light"
                            android:padding="10dp"
                            android:layout_marginStart="6dp">
                            <TextView
                                android:id="@+id/tvStatMateriales"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="@color/ai_primary"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Materiales"
                                android:textSize="11sp"
                                android:textColor="@color/ai_text_muted"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════
                 CARD 2 — Las 4 Competencias
                 Circular = % por competencia (regla del profesor)
                 ═══════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mis Competencias"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/ai_text_dark"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/ai_card_bg"
                app:strokeColor="@color/ai_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Fila 1: C1 + C2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- C1: Cantidad -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:padding="8dp">

                            <FrameLayout
                                android:layout_width="84dp"
                                android:layout_height="84dp">
                                <com.example.aplicacion_tesis.ui.components.DonutChartView
                                    android:id="@+id/donutC1"
                                    android:layout_width="84dp"
                                    android:layout_height="84dp"/>
                                <TextView
                                    android:id="@+id/tvPctC1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="#818CF8"
                                    android:layout_gravity="center"/>
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvNombreC1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cantidad"
                                android:textSize="11sp"
                                android:textColor="@color/ai_text_dark"
                                android:gravity="center"
                                android:layout_marginTop="4dp"/>

                            <TextView
                                android:id="@+id/tvNivelC1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Inicio"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/ai_warning"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <!-- C2: Regularidad -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:padding="8dp">

                            <FrameLayout
                                android:layout_width="84dp"
                                android:layout_height="84dp">
                                <com.example.aplicacion_tesis.ui.components.DonutChartView
                                    android:id="@+id/donutC2"
                                    android:layout_width="84dp"
                                    android:layout_height="84dp"/>
                                <TextView
                                    android:id="@+id/tvPctC2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="#34D399"
                                    android:layout_gravity="center"/>
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvNombreC2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Regularidad"
                                android:textSize="11sp"
                                android:textColor="@color/ai_text_dark"
                                android:gravity="center"
                                android:layout_marginTop="4dp"/>

                            <TextView
                                android:id="@+id/tvNivelC2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Inicio"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/ai_warning"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Fila 2: C3 + C4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- C3: Forma -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:padding="8dp">

                            <FrameLayout
                                android:layout_width="84dp"
                                android:layout_height="84dp">
                                <com.example.aplicacion_tesis.ui.components.DonutChartView
                                    android:id="@+id/donutC3"
                                    android:layout_width="84dp"
                                    android:layout_height="84dp"/>
                                <TextView
                                    android:id="@+id/tvPctC3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="#FB923C"
                                    android:layout_gravity="center"/>
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvNombreC3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Forma / Mov."
                                android:textSize="11sp"
                                android:textColor="@color/ai_text_dark"
                                android:gravity="center"
                                android:layout_marginTop="4dp"/>

                            <TextView
                                android:id="@+id/tvNivelC3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Inicio"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/ai_warning"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <!-- C4: Gestión de Datos -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:padding="8dp">

                            <FrameLayout
                                android:layout_width="84dp"
                                android:layout_height="84dp">
                                <com.example.aplicacion_tesis.ui.components.DonutChartView
                                    android:id="@+id/donutC4"
                                    android:layout_width="84dp"
                                    android:layout_height="84dp"/>
                                <TextView
                                    android:id="@+id/tvPctC4"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0%"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="#C084FC"
                                    android:layout_gravity="center"/>
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvNombreC4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gestión Datos"
                                android:textSize="11sp"
                                android:textColor="@color/ai_text_dark"
                                android:gravity="center"
                                android:layout_marginTop="4dp"/>

                            <TextView
                                android:id="@+id/tvNivelC4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Inicio"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/ai_warning"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════
                 CARD RADAR — Perfil de las 4 Competencias MINEDU
                 ═══════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Perfil de Competencias"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/ai_text_dark"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/ai_card_bg"
                app:strokeColor="@color/ai_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <com.github.mikephil.charting.charts.RadarChart
                        android:id="@+id/radarCompetencias"
                        android:layout_width="match_parent"
                        android:layout_height="240dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cada eje es una competencia MINEDU · 0 – 100%"
                        android:textSize="11sp"
                        android:textColor="@color/ai_text_muted"
                        android:gravity="center"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════
                 CARD 3 — Respuestas por Dificultad
                 Barras = cantidades (regla del profesor)
                 + filas de tasa de acierto (%)
                 ═══════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Respuestas por Dificultad"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/ai_text_dark"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/ai_card_bg"
                app:strokeColor="@color/ai_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Eje Y: cantidad de respuestas -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="N° de respuestas ↑"
                        android:textSize="11sp"
                        android:textColor="@color/ai_text_muted"
                        android:layout_marginBottom="2dp"/>

                    <!-- BarChart: cantidad de respuestas por nivel -->
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/chartBarDificultad"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"/>

                    <!-- Eje X: nivel de dificultad -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nivel de dificultad"
                        android:textSize="11sp"
                        android:textColor="@color/ai_text_muted"
                        android:gravity="center"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvBarEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aún no hay respuestas registradas."
                        android:textColor="@color/ai_text_muted"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="gone"/>

                    <!-- Divisor -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/ai_divider"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tasa de acierto por nivel"
                        android:textSize="12sp"
                        android:textColor="@color/ai_text_muted"
                        android:layout_marginBottom="8dp"/>

                    <!-- Filas dinámicas de acierto -->
                    <LinearLayout
                        android:id="@+id/llDificultad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                    <TextView
                        android:id="@+id/tvDificultadEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sin datos de acierto."
                        android:textColor="@color/ai_text_muted"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:padding="8dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════
                 CARD 4 — Evolución de Puntaje
                 Lineal = tendencia en el tiempo (regla del profesor)
                 ═══════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Evolución de Puntaje"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/ai_text_dark"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/ai_card_bg"
                app:strokeColor="@color/ai_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Eje Y: puntaje -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Puntaje ↑"
                        android:textSize="11sp"
                        android:textColor="@color/ai_text_muted"
                        android:layout_marginBottom="2dp"/>

                    <!-- LineChart: puntaje a lo largo del tiempo -->
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartLineEvolucion"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"/>

                    <!-- Eje X: fecha -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fecha de actividad"
                        android:textSize="11sp"
                        android:textColor="@color/ai_text_muted"
                        android:gravity="center"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvLineEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aún no hay actividad registrada para mostrar la evolución."
                        android:textColor="@color/ai_text_muted"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══════════════════════════════════════════
                 HISTORIAL DE ACTIVIDAD
                 ═══════════════════════════════════════════ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Actividad Reciente"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/ai_text_dark"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvHistorialEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aún no hay actividades registradas."
                android:textColor="@color/ai_text_muted"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistorialProgreso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/btnVerMasHistorial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/ai_primary"
                android:text="Ver más ▼"
                android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <Space android:layout_width="match_parent" android:layout_height="16dp"/>
        </LinearLayout>
    </ScrollView>
</FrameLayout>