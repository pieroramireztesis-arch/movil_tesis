<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefreshInicio"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/ai_bg_screen"
        android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HERO: saludo + progreso general sobre gradiente -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_gradient_card_blue"
            android:elevation="6dp">

            <!-- Orbe decorativo hero -->
            <View
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:background="@drawable/bg_orb_white"
                android:layout_gravity="top|end"
                android:layout_marginTop="-30dp"
                android:layout_marginEnd="-30dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Fila: avatar + saludo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/outline_account_circle_24"
                        app:tint="@color/white"
                        android:background="#33FFFFFF"
                        android:padding="10dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvSaludo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="¡Hola!"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="22sp"/>
                        <TextView
                            android:id="@+id/tvSaludoSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bienvenido de nuevo"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Progreso general -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Progreso General"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvPorcentajeCabecera"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="#33FFFFFF">
                    <ProgressBar
                        android:id="@+id/progressGeneral"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:progress="0"
                        android:max="100"
                        android:progressTint="@color/white"
                        android:progressBackgroundTint="@android:color/transparent"/>
                </FrameLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- ACCESOS RÁPIDOS: Dominio + Tutor lado a lado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- CARD DOMINIO — gradiente azul -->
            <LinearLayout
                android:id="@+id/cardDominio"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:background="@drawable/bg_gradient_card_blue"
                android:elevation="4dp"
                android:padding="16dp"
                android:foreground="?attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="#33FFFFFF"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_training"
                        app:tint="@color/white"/>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dominio"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Practica los temas de álgebra"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:layout_weight="1"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDominio"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    app:backgroundTint="@android:color/transparent"
                    android:text="Empezar"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:strokeColor="@color/white"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="10dp"/>
            </LinearLayout>

            <!-- CARD TUTOR — gradiente índigo -->
            <LinearLayout
                android:id="@+id/cardTutor"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical"
                android:background="@drawable/bg_gradient_card_indigo"
                android:elevation="4dp"
                android:padding="16dp"
                android:foreground="?attr/selectableItemBackground">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="#33FFFFFF"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/outline_ar_on_you_24"
                        app:tint="@color/white"/>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tutor IA"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ayuda personalizada inteligente"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:layout_weight="1"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTutor"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    app:backgroundTint="@android:color/transparent"
                    android:text="Empezar"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:strokeColor="@color/white"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="10dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- TUS DATOS: rendimiento por competencia -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Tu Rendimiento"
            android:textColor="@color/ai_text_dark"
            android:textStyle="bold"
            android:textSize="17sp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDatos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rendimiento por Competencia"
                    android:textColor="@color/ai_text_dark"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:gravity="center">
                    <com.example.aplicacion_tesis.ui.components.DonutChartView
                        android:id="@+id/donutChartView"
                        android:layout_width="180dp"
                        android:layout_height="180dp"
                        android:layout_gravity="center"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_gradient_card_blue" android:layout_marginEnd="10dp"/>
                        <TextView android:id="@+id/tvTema1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Cantidad" android:textColor="@color/ai_text_dark" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvTema1Pct" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textStyle="bold" android:textColor="@color/ai_comp1" android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_gradient_card_green" android:layout_marginEnd="10dp"/>
                        <TextView android:id="@+id/tvTema2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Regularidad" android:textColor="@color/ai_text_dark" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvTema2Pct" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textStyle="bold" android:textColor="@color/ai_comp2" android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_gradient_card_orange" android:layout_marginEnd="10dp"/>
                        <TextView android:id="@+id/tvTema3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Forma y movimiento" android:textColor="@color/ai_text_dark" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvTema3Pct" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textStyle="bold" android:textColor="@color/ai_comp3" android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_gradient_card_indigo" android:layout_marginEnd="10dp"/>
                        <TextView android:id="@+id/tvTema4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Datos e incertidumbre" android:textColor="@color/ai_text_dark" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvTema4Pct" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textStyle="bold" android:textColor="@color/ai_comp4" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnComoSeCalcula"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="16dp"
                    android:text="¿Cómo se calcula mi progreso?"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    android:textColor="@color/ai_primary"
                    app:strokeColor="@color/ai_primary"
                    app:cornerRadius="10dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerReporte"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    app:backgroundTint="@color/ai_primary"
                    android:text="Ver Reporte Completo"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:cornerRadius="10dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Space android:layout_width="0dp" android:layout_height="24dp"/>
    </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>