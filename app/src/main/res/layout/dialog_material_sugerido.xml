<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:fillViewport="false">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="24dp">

    <!-- Ícono -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_nav_book"
        android:padding="10dp"
        android:background="@drawable/bg_circle_light"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:tint="@color/ai_primary"
        android:importantForAccessibility="no"/>

    <!-- Título -->
    <TextView
        android:id="@+id/tvDialogMaterialTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Refuerza este tema"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/ai_text_dark"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <!-- Subtítulo -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Usa estos recursos para entender mejor el ejercicio"
        android:textSize="12sp"
        android:textColor="@color/ai_text_muted"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Contexto del fallo — visible solo si hay ejercicio identificado -->
    <TextView
        android:id="@+id/tvDialogContexto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="@color/ai_warning"
        android:gravity="center"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="12dp"
        android:visibility="gone"/>

    <!-- Separador -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ai_divider"
        android:layout_marginBottom="14dp" />

    <!-- ══ SECCIÓN: Material del docente (se oculta si no hay material) ══ -->
    <LinearLayout
        android:id="@+id/layoutMaterialDocente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Tipo de material -->
        <TextView
            android:id="@+id/tvDialogMaterialTipo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶  Video recomendado"
            android:textSize="12sp"
            android:textColor="@color/ai_text_muted"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <!-- Nombre del material -->
        <TextView
            android:id="@+id/tvDialogMaterialNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título del material"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/ai_primary"
            android:gravity="center"
            android:layout_marginBottom="10dp" />

        <!-- Bloque timer — visible solo después de abrir -->
        <LinearLayout
            android:id="@+id/layoutTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvTimerLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Revisa el material al menos la mitad del tiempo estimado"
                android:textSize="12sp"
                android:textColor="@color/ai_text_muted"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <ProgressBar
                android:id="@+id/progressTimer"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/ai_primary"
                android:progressBackgroundTint="@color/ai_progress_track"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvTimerCountdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tiempo restante: --"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/ai_primary"
                android:gravity="center" />
        </LinearLayout>

        <!-- Botón abrir material del docente -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogAbrirMaterial"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🔗  Abrir material del tema"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/ai_primary"
            android:layout_marginBottom="10dp" />

        <!-- Separador antes de búsqueda -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/ai_divider"
            android:layout_marginBottom="12dp" />
    </LinearLayout>

    <!-- ══ SECCIÓN: Buscar recursos en línea ══ -->
    <LinearLayout
        android:id="@+id/layoutRecursosOnline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 Busca más ayuda en línea"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/ai_text_dark"
            android:gravity="center"
            android:layout_marginBottom="10dp" />

        <!-- Botón YouTube -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogYoutube"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="📺  Ver videos en YouTube"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:backgroundTint="#CC0000"
            android:layout_marginBottom="8dp" />

        <!-- Botón Recursos Web -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogWebRecursos"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="🌐  Buscar recursos en web"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="8dp" />

        <!-- Botón PDF -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogPdf"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="📄  Buscar PDF / apuntes"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:backgroundTint="#E65100"
            android:layout_marginBottom="12dp" />

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/ai_divider"
            android:layout_marginBottom="12dp" />
    </LinearLayout>

    <!-- Botón continuar — bloqueado 60s al inicio para forzar mínima atención -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDialogContinuar"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Disponible en 60s..."
        android:textAllCaps="false"
        android:enabled="false"
        android:alpha="0.5"
        android:textColor="@color/ai_text_muted" />

    <!-- ══ CHECKPOINT de comprensión — visible solo al hacer clic en Continuar ══ -->
    <LinearLayout
        android:id="@+id/layoutCheckpoint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/ai_divider"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Ícono -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧠"
            android:textSize="32sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <!-- Pregunta -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¿Crees que ya puedes resolver esto?"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/ai_text_dark"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Enunciado del ejercicio -->
        <TextView
            android:id="@+id/tvCheckpointEnunciado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/ai_text_dark"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginBottom="16dp"
            android:lineSpacingExtra="4dp" />

        <!-- Botón SÍ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckpointSi"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="✊  Sí, intentarlo ahora"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/ai_primary"
            android:layout_marginBottom="8dp" />

        <!-- Botón REVISAR MÁS -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckpointRevisar"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🔄  Necesito revisar más"
            android:textAllCaps="false"
            android:textColor="@color/ai_text_muted" />

    </LinearLayout>

</LinearLayout>

</ScrollView>
