<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_bg_screen"
    android:fitsSystemWindows="true">

    <!-- Orbes decorativos de fondo -->
    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_orb_white"
        android:layout_gravity="top|end"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-50dp"/>
    <View
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_orb_white"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-30dp"
        android:layout_marginStart="-30dp"/>

    <!-- Símbolos matemáticos decorativos -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="∑"
        android:textColor="#45FFFFFF"
        android:textSize="90sp"
        android:textStyle="bold"
        android:layout_gravity="top|end"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="10dp"
        android:importantForAccessibility="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="x²"
        android:textColor="#38FFFFFF"
        android:textSize="64sp"
        android:textStyle="bold"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="6dp"
        android:importantForAccessibility="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="="
        android:textColor="#2CFFFFFF"
        android:textSize="72sp"
        android:textStyle="bold"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="120dp"
        android:layout_marginEnd="12dp"
        android:importantForAccessibility="no"/>

    <!-- CONTENIDO PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ══ HEADER GRADIENTE ══ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@drawable/bg_gradient_header">

            <!-- Orbe pequeño decorativo -->
            <View
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_orb_white"
                android:layout_gravity="top|end"
                android:layout_marginTop="-15dp"
                android:layout_marginEnd="-15dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBackPractica"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="10dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_arrow_back_24"
                    android:contentDescription="@string/volver"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTituloTutor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ejercicio de práctica"
                        android:textStyle="bold"
                        android:textSize="17sp"
                        android:textColor="@color/white"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/tvModoPracticaInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No modifica tu progreso"
                        android:textSize="12sp"
                        android:textColor="#CCFFFFFF"
                        android:maxLines="1"/>
                </LinearLayout>

                <!-- Chip modo práctica -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Práctica"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="#33FFFFFF"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"/>

            </LinearLayout>
        </FrameLayout>

        <!-- ══ CONTENIDO SCROLL ══ -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:fillViewport="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- CARD ENUNCIADO -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/ai_card_bg"
                    app:strokeColor="@color/ai_card_stroke"
                    app:strokeWidth="1.5dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Chip competencia -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Álgebra"
                            android:textColor="@color/ai_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="#20818CF8"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp"
                            android:layout_marginBottom="14dp"/>

                        <!-- Imagen del problema (opcional) -->
                        <ImageView
                            android:id="@+id/imgProblema"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            android:adjustViewBounds="true"
                            android:scaleType="fitCenter"
                            android:visibility="gone"
                            android:contentDescription="@string/app_name"/>

                        <!-- Enunciado -->
                        <TextView
                            android:id="@+id/tvEnunciado"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Resuelve para x: 2x + 5 = 15"
                            android:textSize="17sp"
                            android:lineSpacingMultiplier="1.4"
                            android:textColor="@color/ai_text_dark"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Label opciones -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selecciona tu respuesta"
                    android:textColor="@color/ai_text_muted"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <!-- OPCIONES DE RESPUESTA -->
                <RadioGroup
                    android:id="@+id/rgAlternativas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbA"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="A) opción 1"
                        android:textSize="15sp"
                        android:textColor="@color/ai_text_dark"
                        android:buttonTint="@color/ai_primary"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp"
                        android:background="@drawable/bg_option_card"
                        android:layout_marginBottom="10dp"/>

                    <RadioButton
                        android:id="@+id/rbB"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="B) opción 2"
                        android:textSize="15sp"
                        android:textColor="@color/ai_text_dark"
                        android:buttonTint="@color/ai_primary"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp"
                        android:background="@drawable/bg_option_card"
                        android:layout_marginBottom="10dp"/>

                    <RadioButton
                        android:id="@+id/rbC"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="C) opción 3"
                        android:textSize="15sp"
                        android:textColor="@color/ai_text_dark"
                        android:buttonTint="@color/ai_primary"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp"
                        android:background="@drawable/bg_option_card"
                        android:layout_marginBottom="10dp"/>

                    <RadioButton
                        android:id="@+id/rbD"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="D) opción 4"
                        android:textSize="15sp"
                        android:textColor="@color/ai_text_dark"
                        android:buttonTint="@color/ai_primary"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp"
                        android:background="@drawable/bg_option_card"
                        android:layout_marginBottom="10dp"/>

                    <RadioButton
                        android:id="@+id/rbE"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="E) opción 5"
                        android:textSize="15sp"
                        android:textColor="@color/ai_text_dark"
                        android:buttonTint="@color/ai_primary"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp"
                        android:background="@drawable/bg_option_card"
                        android:layout_marginBottom="10dp"/>

                </RadioGroup>

                <!-- CARD PISTA / FEEDBACK -->
                <LinearLayout
                    android:id="@+id/cardFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_gradient_card_indigo"
                    android:padding="18dp"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_lightbulb"
                            android:padding="6dp"
                            android:background="#33FFFFFF"
                            android:tint="#FFFDE7"
                            android:importantForAccessibility="no"/>

                        <TextView
                            android:id="@+id/tvFeedbackTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="¡Aquí tienes una pista!"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="@color/white"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Recuerda aislar la variable 'x'."
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"
                        android:textColor="#CCFFFFFF"/>

                </LinearLayout>

                <!-- BOTONES -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:weightSum="2">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubirFoto"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="Sube tu desarrollo"
                        android:textAllCaps="false"
                        android:textColor="@color/ai_primary"
                        android:layout_marginEnd="8dp"
                        app:strokeColor="@color/ai_primary"
                        app:cornerRadius="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEnviar"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="Verificar"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginStart="8dp"
                        app:backgroundTint="@color/ai_primary"
                        app:cornerRadius="12dp"/>

                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="32dp"/>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>
</FrameLayout>