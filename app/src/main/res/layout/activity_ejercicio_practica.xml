<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_background_light"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ====== CABECERA: Back + título ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/btnBackPractica"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_arrow_back_24"
                android:contentDescription="@string/volver" />

            <TextView
                android:id="@+id/tvTituloTutor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ejercicio de práctica"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/ai_text_dark" />
        </LinearLayout>

        <!-- Mensaje de modo práctica -->
        <TextView
            android:id="@+id/tvModoPracticaInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Este ejercicio es solo para practicar. No modificará tu progreso."
            android:textSize="13sp"
            android:textColor="@color/ai_text_muted"
            android:layout_marginBottom="12dp" />

        <!-- Card del enunciado / imagen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="16dp">

            <!-- Imagen del problema (opcional) -->
            <ImageView
                android:id="@+id/imgProblema"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="@string/app_name" />

            <!-- Enunciado -->
            <TextView
                android:id="@+id/tvEnunciado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resuelve para x en la siguiente ecuación: 2x + 5 = 15"
                android:textSize="16sp"
                android:textColor="@color/ai_text_dark" />

        </LinearLayout>

        <!-- Opciones de respuesta -->
        <RadioGroup
            android:id="@+id/rgAlternativas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A) opción 1"
                android:textSize="15sp"
                android:textColor="@color/ai_text_dark"
                android:buttonTint="@color/ai_primary"
                android:padding="14dp"
                android:background="@drawable/bg_option_card"
                android:layout_marginBottom="8dp" />

            <RadioButton
                android:id="@+id/rbB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="B) opción 2"
                android:textSize="15sp"
                android:textColor="@color/ai_text_dark"
                android:buttonTint="@color/ai_primary"
                android:padding="14dp"
                android:background="@drawable/bg_option_card"
                android:layout_marginBottom="8dp" />

            <RadioButton
                android:id="@+id/rbC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="C) opción 3"
                android:textSize="15sp"
                android:textColor="@color/ai_text_dark"
                android:buttonTint="@color/ai_primary"
                android:padding="14dp"
                android:background="@drawable/bg_option_card"
                android:layout_marginBottom="8dp" />

            <RadioButton
                android:id="@+id/rbD"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="D) opción 4"
                android:textSize="15sp"
                android:textColor="@color/ai_text_dark"
                android:buttonTint="@color/ai_primary"
                android:padding="14dp"
                android:background="@drawable/bg_option_card"
                android:layout_marginBottom="8dp" />

            <RadioButton
                android:id="@+id/rbE"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="E) opción 5"
                android:textSize="15sp"
                android:textColor="@color/ai_text_dark"
                android:buttonTint="@color/ai_primary"
                android:padding="14dp"
                android:background="@drawable/bg_option_card"
                android:layout_marginBottom="8dp" />

        </RadioGroup>

        <!-- Tarjeta de pista / feedback -->
        <LinearLayout
            android:id="@+id/cardFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_accent"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvFeedbackTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¡Sigue intentando! Aquí tienes una pista:"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/ai_text_dark" />

            <TextView
                android:id="@+id/tvFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Recuerda aislar la variable 'x' en un lado de la ecuación."
                android:textSize="14sp"
                android:textColor="@color/ai_text_dark" />
        </LinearLayout>

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubirFoto"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Sube tu desarrollo"
                android:textAllCaps="false"
                android:textColor="@color/ai_primary"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnviar"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Verificar respuesta"
                android:textAllCaps="false"
                android:backgroundTint="@color/ai_primary"
                android:textColor="@android:color/white"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>
