<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_bg_screen"
    android:fillViewport="true">
        <LinearLayout
            android:id="@+id/container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- SALUDO -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¡Hola, Profesor!"
                android:textColor="@color/ai_text_dark"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- TARJETAS RESUMEN 2x2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <!-- Matriculados — gradiente azul -->
                <LinearLayout
                    android:id="@+id/cardEstudiantesActivos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_gradient_card_blue"
                    android:elevation="4dp"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="#33FFFFFF"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_person"
                            app:tint="@color/white"
                            xmlns:app="http://schemas.android.com/apk/res-auto"/>
                    </FrameLayout>
                    <TextView
                        android:id="@+id/tvEstudiantesActivos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="32sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Matriculados"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- Progreso promedio — gradiente verde -->
                <LinearLayout
                    android:id="@+id/cardProgresoPromedio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_gradient_card_green"
                    android:elevation="4dp"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="#33FFFFFF"
                        android:layout_marginBottom="8dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_chart"
                            app:tint="@color/white"
                            xmlns:app="http://schemas.android.com/apk/res-auto"/>
                    </FrameLayout>
                    <TextView
                        android:id="@+id/tvProgresoPromedio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/white"
                        android:textSize="32sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Progreso"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- COMPETENCIA CON MÁS DIFICULTADES — gradiente naranja -->
            <LinearLayout
                android:id="@+id/cardTemaDificil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_gradient_card_orange"
                android:elevation="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Competencia con más dificultades"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvTemaDificil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="#33FFFFFF">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_warning"
                        app:tint="@color/white"
                        android:contentDescription="Competencia con dificultades"
                        xmlns:app="http://schemas.android.com/apk/res-auto"/>
                </FrameLayout>
            </LinearLayout>

            <!-- BOTÓN VER INFORMES -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerInformes"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="20dp"
                android:text="Ver Informes de Estudiantes"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/white"
                app:backgroundTint="@color/ai_primary"
                app:cornerRadius="14dp"/>

            <!-- ACTIVIDAD RECIENTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView
                    android:id="@+id/tvActividadRecienteTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Actividad Reciente"
                    android:textColor="@color/ai_text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvVerTodaActividad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver informes ›"
                    android:textColor="@color/ai_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Actividad 1 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardActividad1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/tvActividad1Titulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="---"
                        android:textColor="@color/ai_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvActividad1Tiempo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/ai_text_muted"
                        android:textSize="12sp"
                        android:paddingTop="3dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Actividad 2 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardActividad2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/ai_primary_light">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/tvActividad2Titulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="---"
                        android:textColor="@color/ai_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvActividad2Tiempo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/ai_primary"
                        android:textSize="12sp"
                        android:paddingTop="3dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Actividad 3 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardActividad3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/tvActividad3Titulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="---"
                        android:textColor="@color/ai_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvActividad3Tiempo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/ai_text_muted"
                        android:textSize="12sp"
                        android:paddingTop="3dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- USO DE LA APLICACIÓN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Uso de la Aplicación"
                android:textColor="@color/ai_text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:id="@+id/cardFrecuencia1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="10dp"
                        android:visibility="gone">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:padding="3dp"
                            android:src="@drawable/ic_medal"
                            app:tint="#F1C40F"
                            android:contentDescription="Puesto"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:id="@+id/tvFrecuencia1Nombre"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="---"
                                android:textColor="@color/ai_text_dark"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvFrecuencia1Detalle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0 interacciones"
                                android:textColor="@color/ai_text_muted"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvFrecuencia1Total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/ai_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/divFrecuencia1"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/ai_divider"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/cardFrecuencia2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="10dp"
                        android:visibility="gone">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:padding="3dp"
                            android:src="@drawable/ic_medal"
                            app:tint="#95A5A6"
                            android:contentDescription="Puesto"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:id="@+id/tvFrecuencia2Nombre"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="---"
                                android:textColor="@color/ai_text_dark"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvFrecuencia2Detalle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0 interacciones"
                                android:textColor="@color/ai_text_muted"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvFrecuencia2Total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/ai_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/divFrecuencia2"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/ai_divider"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/cardFrecuencia3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="10dp"
                        android:visibility="gone">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:padding="3dp"
                            android:src="@drawable/ic_medal"
                            app:tint="#CD7F32"
                            android:contentDescription="Puesto"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:id="@+id/tvFrecuencia3Nombre"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="---"
                                android:textColor="@color/ai_text_dark"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvFrecuencia3Detalle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0 interacciones"
                                android:textColor="@color/ai_text_muted"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvFrecuencia3Total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/ai_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvFrecuenciaVacia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aún no hay datos de uso registrados."
                        android:textColor="@color/ai_text_muted"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
</ScrollView>
