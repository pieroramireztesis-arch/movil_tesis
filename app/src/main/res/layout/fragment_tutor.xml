<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_bg_screen"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TÍTULO + BADGE DE RACHA (A2) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvTituloTutor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Práctica de Álgebra"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/ai_text_dark"/>

            <TextView
                android:id="@+id/tvRachaBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- SELECTOR MODO Repaso / Evaluación -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/ai_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/btnModoRepaso"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Repaso"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_tab_selected_left"/>

                <TextView
                    android:id="@+id/btnModoEvaluacion"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Evaluación"
                    android:textSize="14sp"
                    android:textColor="@color/ai_text_muted"
                    android:background="@drawable/bg_tab_selected_right"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- BADGE MODO -->
        <TextView
            android:id="@+id/tvBadgeModo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modo Repaso — Las pistas están disponibles"
            android:textSize="12sp"
            android:textColor="@color/ai_primary"
            android:layout_marginBottom="12dp"/>

        <!-- Nivel ML -->
        <TextView
            android:id="@+id/tvNivelActual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/ai_primary"
            android:padding="8dp"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="10dp"
            android:visibility="gone"/>

        <!-- CARD EVALUACIÓN ACTIVA -->
        <LinearLayout
            android:id="@+id/cardEvaluacionActiva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@color/ai_primary"
                android:padding="24dp"
                android:orientation="vertical"
                android:gravity="bottom">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝  EVALUACIÓN ACTIVA"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"/>

                <TextView
                    android:id="@+id/tvEvaluacionTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Título"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/ai_card_bg"
                android:padding="24dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvEvaluacionDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Descripción"
                    android:textColor="@color/ai_text_dark"
                    android:textSize="15sp"
                    android:lineSpacingExtra="6dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:background="@color/ai_divider"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@color/ai_primary_light"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️"
                        android:textSize="18sp"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sin pistas disponibles"
                            android:textColor="@color/ai_primary_dark"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lee bien cada pregunta antes de responder"
                            android:textColor="@color/ai_primary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIniciarEvaluacion"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="Iniciar Evaluación  ▶"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/ai_primary"
                    app:cornerRadius="12dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- CARD EJERCICIO -->
        <LinearLayout
            android:id="@+id/cardEjercicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="16dp">

            <!-- A1: Barra de retroalimentación animada (verde=correcto / rojo=incorrecto) -->
            <View
                android:id="@+id/viewProgressBar"
                android:layout_width="0dp"
                android:layout_height="5dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"/>

            <!-- Chip de competencia — visible solo en repaso -->
            <TextView
                android:id="@+id/tvCompetenciaTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"/>

            <ImageView
                android:id="@+id/imgProblema"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="12dp"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:visibility="gone"
                android:contentDescription="@string/app_name"/>

            <TextView
                android:id="@+id/tvEnunciado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cargando ejercicio..."
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/ai_text_dark"/>
        </LinearLayout>

        <!-- OPCIONES -->
        <RadioGroup
            android:id="@+id/rgAlternativas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A)"
                android:textSize="15sp"
                android:textColor="@color/ai_text_dark"
                android:buttonTint="@color/ai_primary"
                android:padding="14dp"
                android:background="@drawable/bg_option_card"
                android:layout_marginBottom="8dp"/>

            <RadioButton
                android:id="@+id/rbB"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="B)"
                android:textSize="15sp"
                android:textColor="@color/ai_text_dark"
                android:buttonTint="@color/ai_primary"
                android:padding="14dp"
                android:background="@drawable/bg_option_card"
                android:layout_marginBottom="8dp"/>

            <RadioButton
                android:id="@+id/rbC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="C)"
                android:textSize="15sp"
                android:textColor="@color/ai_text_dark"
                android:buttonTint="@color/ai_primary"
                android:padding="14dp"
                android:background="@drawable/bg_option_card"
                android:layout_marginBottom="8dp"/>

            <RadioButton
                android:id="@+id/rbD"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="D)"
                android:textSize="15sp"
                android:textColor="@color/ai_text_dark"
                android:buttonTint="@color/ai_primary"
                android:padding="14dp"
                android:background="@drawable/bg_option_card"
                android:layout_marginBottom="8dp"/>

            <RadioButton
                android:id="@+id/rbE"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="E)"
                android:textSize="15sp"
                android:textColor="@color/ai_text_dark"
                android:buttonTint="@color/ai_primary"
                android:padding="14dp"
                android:background="@drawable/bg_option_card"
                android:layout_marginBottom="8dp"/>
        </RadioGroup>

        <!-- FEEDBACK / PISTA -->
        <LinearLayout
            android:id="@+id/cardFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:background="@color/ai_primary_light">

            <TextView
                android:id="@+id/tvFeedbackTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💡 Pista"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/ai_primary"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/ai_text_dark"/>
        </LinearLayout>

        <!-- RESULTADO EVALUACIÓN (A3) -->
        <LinearLayout
            android:id="@+id/cardResultadoEvaluacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_marginTop="16dp"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_card"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉 Evaluación completada"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/ai_text_dark"
                android:layout_marginBottom="20dp"/>

            <!-- Score grande en círculo coloreado -->
            <FrameLayout
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp">

                <com.example.aplicacion_tesis.ui.components.DonutChartView
                    android:id="@+id/donutResultado"
                    android:layout_width="140dp"
                    android:layout_height="140dp"/>

                <TextView
                    android:id="@+id/tvResultadoPuntaje"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="@color/ai_primary"
                    android:layout_gravity="center"/>
            </FrameLayout>

            <!-- Correctas y nivel MINEDU -->
            <TextView
                android:id="@+id/tvResultadoCorrectas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correctas: 0 / 0"
                android:textSize="15sp"
                android:textColor="@color/ai_text_muted"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvNivelResultado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginBottom="6dp"
                android:visibility="gone"/>

            <!-- Mensaje motivacional (M9) -->
            <TextView
                android:id="@+id/tvResultadoMensaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:gravity="center"
                android:textColor="@color/ai_text_muted"
                android:layout_marginBottom="20dp"/>

            <!-- Barra de progreso visual del score -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ai_divider"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVolverRepaso"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="¿Hay nueva evaluación?"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:backgroundTint="@color/ai_primary"
                app:cornerRadius="12dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerProgreso"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Ver mi progreso →"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="@color/ai_primary"
                app:strokeColor="@color/ai_primary"
                app:cornerRadius="12dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- BOTONES ACCIÓN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubirFoto"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Sube tu desarrollo"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="@color/ai_primary"
                android:layout_marginEnd="6dp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/ai_primary"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnviar"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Verificar respuesta"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:backgroundTint="@color/ai_primary"
                android:textColor="@color/white"
                android:layout_marginStart="6dp"
                app:cornerRadius="12dp"/>
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="72dp"/>
    </LinearLayout>
</ScrollView>

<!-- A11: overlay de confetti — se activa programáticamente al subir de nivel -->
<com.example.aplicacion_tesis.ui.components.ConfettiView
    android:id="@+id/confettiView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone"
    android:clickable="false"
    android:importantForAccessibility="no" />

<com.google.android.material.floatingactionbutton.FloatingActionButton
    android:id="@+id/btnSonido"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|end"
    android:layout_margin="16dp"
    android:src="@drawable/ic_volume_on"
    android:contentDescription="Activar o desactivar sonido"
    app:backgroundTint="@color/ai_primary"
    app:fabSize="mini"
    app:tint="@color/white"
    app:elevation="6dp"/>

</FrameLayout>