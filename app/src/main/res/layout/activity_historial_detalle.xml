<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_bg_screen">

    <!-- TOOLBAR -->
    <LinearLayout
        android:id="@+id/layoutToolbarDetalle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="14dp"
        android:gravity="center_vertical"
        android:background="@color/ai_card_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBackHistorial"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_outline"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back_24"
            android:contentDescription="@string/volver" />

        <TextView
            android:id="@+id/tvToolbarDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Detalle del ejercicio"
            android:textAlignment="center"
            android:textColor="@color/ai_text_dark"
            android:textSize="17sp"
            android:textStyle="bold" />

        <View android:layout_width="40dp" android:layout_height="40dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbarDetalle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TARJETA EJERCICIO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ejercicio"
                        android:textColor="@color/ai_text_muted"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvTituloDetalle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Título del ejercicio"
                        android:textColor="@color/ai_text_dark"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="2dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/ai_divider"
                        android:layout_marginVertical="12dp" />

                    <!-- Resultado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ivResultadoIcono"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_check_circle_24"
                            app:tint="@color/ai_success" />

                        <TextView
                            android:id="@+id/tvResultadoEstado"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:text="Correcto"
                            android:textColor="@color/ai_text_dark"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECCIÓN DESARROLLO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📎  Tu desarrollo"
                android:textColor="@color/ai_text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <!-- Imagen desarrollo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardImagen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <ImageView
                    android:id="@+id/ivDesarrollo"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

            <!-- Botón PDF -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPdf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <TextView
                    android:id="@+id/btnAbrirPdf"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Ver desarrollo (PDF)"
                    android:textColor="@color/ai_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </androidx.cardview.widget.CardView>

            <!-- Sin desarrollo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSinDesarrollo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardUseCompatPadding="true">

                <TextView
                    android:id="@+id/tvSinDesarrollo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sin archivo de desarrollo registrado."
                    android:textColor="@color/ai_text_muted"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="20dp" />
            </androidx.cardview.widget.CardView>

            <!-- SECCIÓN MATERIAL REFUERZO -->
            <LinearLayout
                android:id="@+id/layoutMaterialRefuerzo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Material de refuerzo"
                    android:textColor="@color/ai_text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"
                    android:layout_marginStart="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Revisa estos materiales para mejorar en este tema:"
                    android:textColor="@color/ai_text_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="10dp"
                    android:layout_marginStart="4dp" />

                <TextView
                    android:id="@+id/tvCargandoMaterial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Buscando materiales..."
                    android:textColor="@color/ai_text_muted"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="16dp" />

                <LinearLayout
                    android:id="@+id/layoutMateriales"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>