<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ai_bg_screen">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="3dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Panel de Profesor"
                android:textColor="@color/ai_text_dark"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/ivProfile"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="7dp"
                android:src="@drawable/outline_attribution_24"
                android:background="@drawable/bg_primary_circle"
                android:contentDescription="@string/profile"
                android:clickable="false"
                android:focusable="false"/>
        </LinearLayout>

        <!-- TABS -->
        <LinearLayout
            android:id="@+id/layoutTeacherTabs"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/tabTeacherInicio"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvTabTeacherInicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inicio"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:textStyle="bold"
                    android:textColor="@color/ai_primary"/>
                <View
                    android:id="@+id/indicatorTeacherInicio"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="4dp"
                    android:background="@color/ai_primary"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabTeacherInformes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvTabTeacherInformes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informes"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:textColor="@color/ai_text_muted"/>
                <View
                    android:id="@+id/indicatorTeacherInformes"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="4dp"
                    android:background="@color/ai_primary"
                    android:visibility="gone"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabTeacherAlertas"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvTabTeacherAlertas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alertas"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:textColor="@color/ai_text_muted"/>
                <View
                    android:id="@+id/indicatorTeacherAlertas"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="4dp"
                    android:background="@color/ai_primary"
                    android:visibility="gone"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabTeacherPerfil"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvTabTeacherPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Perfil"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:textColor="@color/ai_text_muted"/>
                <View
                    android:id="@+id/indicatorTeacherPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="4dp"
                    android:background="@color/ai_primary"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- CONTENIDO SCROLLABLE -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- SALUDO -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¡Hola, Profesor!"
                android:textColor="@color/ai_text_dark"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- TARJETAS RESUMEN 2x2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <!-- Matriculados -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardEstudiantesActivos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👥 Matriculados"
                            android:textColor="@color/ai_text_muted"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp"/>
                        <TextView
                            android:id="@+id/tvEstudiantesActivos"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/ai_primary"
                            android:textSize="32sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Progreso promedio -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardProgresoPromedio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊 Progreso"
                            android:textColor="@color/ai_text_muted"
                            android:textSize="12sp"
                            android:layout_marginBottom="6dp"/>
                        <TextView
                            android:id="@+id/tvProgresoPromedio"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/ai_progress"
                            android:textSize="32sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- COMPETENCIA CON MÁS DIFICULTADES -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTemaDificil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Competencia con más dificultades"
                            android:textColor="@color/ai_text_muted"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tvTemaDificil"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/ai_warning"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="⚠️"
                        android:textSize="22sp"
                        android:gravity="center"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- BOTÓN VER INFORMES -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerInformes"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="20dp"
                android:text="Ver Informes de Estudiantes"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/white"
                app:backgroundTint="@color/ai_primary"
                app:cornerRadius="14dp"/>

            <!-- ACTIVIDAD RECIENTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView
                    android:id="@+id/tvActividadRecienteTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Actividad Reciente"
                    android:textColor="@color/ai_text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvVerTodaActividad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver informes ›"
                    android:textColor="@color/ai_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Actividad 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardActividad1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/tvActividad1Titulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="---"
                        android:textColor="@color/ai_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvActividad1Tiempo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/ai_text_muted"
                        android:textSize="12sp"
                        android:paddingTop="3dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Actividad 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardActividad2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/ai_primary_light">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/tvActividad2Titulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="---"
                        android:textColor="@color/ai_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvActividad2Tiempo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/ai_primary"
                        android:textSize="12sp"
                        android:paddingTop="3dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Actividad 3 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardActividad3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/tvActividad3Titulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="---"
                        android:textColor="@color/ai_text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvActividad3Tiempo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/ai_text_muted"
                        android:textSize="12sp"
                        android:paddingTop="3dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- USO DE LA APLICACIÓN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Uso de la Aplicación"
                android:textColor="@color/ai_text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:id="@+id/cardFrecuencia1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="10dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="🥇"
                            android:textSize="18sp"
                            android:gravity="center"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:id="@+id/tvFrecuencia1Nombre"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="---"
                                android:textColor="@color/ai_text_dark"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvFrecuencia1Detalle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0 interacciones"
                                android:textColor="@color/ai_text_muted"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvFrecuencia1Total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/ai_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/divFrecuencia1"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/ai_divider"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/cardFrecuencia2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="10dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="🥈"
                            android:textSize="18sp"
                            android:gravity="center"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:id="@+id/tvFrecuencia2Nombre"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="---"
                                android:textColor="@color/ai_text_dark"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvFrecuencia2Detalle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0 interacciones"
                                android:textColor="@color/ai_text_muted"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvFrecuencia2Total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/ai_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/divFrecuencia2"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/ai_divider"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:id="@+id/cardFrecuencia3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="10dp"
                        android:visibility="gone">
                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="🥉"
                            android:textSize="18sp"
                            android:gravity="center"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:id="@+id/tvFrecuencia3Nombre"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="---"
                                android:textColor="@color/ai_text_dark"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvFrecuencia3Detalle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0 interacciones"
                                android:textColor="@color/ai_text_muted"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvFrecuencia3Total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/ai_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvFrecuenciaVacia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aún no hay datos de uso registrados."
                        android:textColor="@color/ai_text_muted"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>