<?xml version="1.0" encoding="utf-8"?>
<!-- HOST DOCENTE — F2 rediseño:
     UNA sola Activity con header de marca + ViewPager2 (4 fragments)
     + Bottom Navigation M3, igual que el lado estudiante.
     (Antes: 4 Activities separadas con una barra de tabs artesanal
     duplicada que recargaba toda la pantalla en cada cambio.) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ai_bg_screen">

    <include layout="@layout/include_brand_header"/>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerTeacher"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavTeacher"
        style="@style/Widget.TutorMath.BottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/menu_bottom_teacher"/>

</LinearLayout>