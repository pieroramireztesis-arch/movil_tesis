<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/pageRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Símbolos decorativos matemáticos -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="∑"
        android:textColor="#18FFFFFF"
        android:textSize="88sp"
        android:textStyle="bold"
        android:layout_gravity="top|start"
        android:layout_marginTop="24dp"
        android:layout_marginStart="8dp"
        android:importantForAccessibility="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="π"
        android:textColor="#14FFFFFF"
        android:textSize="72sp"
        android:textStyle="bold"
        android:layout_gravity="top|end"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="16dp"
        android:importantForAccessibility="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="≠"
        android:textColor="#10FFFFFF"
        android:textSize="56sp"
        android:textStyle="bold"
        android:layout_gravity="center|start"
        android:layout_marginStart="24dp"
        android:importantForAccessibility="no"/>

    <!-- Contenido principal — centrado en el 60% superior -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal|center_vertical"
        android:paddingHorizontal="36dp"
        android:paddingBottom="200dp">

        <!-- Círculo de fondo del ícono -->
        <FrameLayout
            android:layout_width="136dp"
            android:layout_height="136dp"
            android:background="@drawable/bg_ob_icon">

            <ImageView
                android:id="@+id/ivOnboardingIcon"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_gravity="center"
                android:tint="@android:color/white"/>

        </FrameLayout>

        <TextView
            android:id="@+id/tvOnboardingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"/>

        <TextView
            android:id="@+id/tvOnboardingSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="15sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"/>

    </LinearLayout>

</FrameLayout>