<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_bg_screen"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ai_card_bg"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Módulo de Dominio"
            android:textColor="@color/ai_text_dark"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Álgebra — MINEDU"
            android:textColor="@color/ai_text_muted"
            android:textSize="13sp" />

        <!-- Estadísticas generales -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Total materiales -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="10dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/tvTotalMateriales"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/ai_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textColor="@color/ai_text_muted"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Vistos -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="10dp"
                android:layout_marginHorizontal="4dp">

                <TextView
                    android:id="@+id/tvTotalVistos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/ai_success"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vistos"
                    android:textColor="@color/ai_text_muted"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Progreso % -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="10dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:id="@+id/tvPorcentajeGeneral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/ai_accent"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Avance"
                    android:textColor="@color/ai_text_muted"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- CHIPS filtro -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipTodos"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_selected"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Todos"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipBasico"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_unselected"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Básico"
                android:textColor="@color/ai_text_dark"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipIntermedio"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_unselected"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Intermedio"
                android:textColor="@color/ai_text_dark"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipAvanzado"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_chip_unselected"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Avanzado"
                android:textColor="@color/ai_text_dark"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- LISTA DE TEMAS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTemasDominio"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>