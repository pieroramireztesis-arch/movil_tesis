<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="24dp">

    <!-- Título -->
    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seguimiento de alerta"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0A0F14"
        android:gravity="center"
        android:layout_marginBottom="6dp" />

    <!-- Nombre del estudiante -->
    <TextView
        android:id="@+id/dialogStudentName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="#0A6FD4"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#B0BEC5"
        android:layout_marginBottom="12dp" />

    <!-- Descripción -->
    <TextView
        android:id="@+id/dialogDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#2C5282"
        android:lineSpacingExtra="3dp"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Fecha -->
    <TextView
        android:id="@+id/dialogFecha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#2C5282"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- Botón principal -->
    <TextView
        android:id="@+id/btnAtendida"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Se le dio seguimiento"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#0A6FD4"
        android:layout_marginBottom="10dp" />

    <!-- Botón cancelar -->
    <TextView
        android:id="@+id/btnCancelar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Cancelar"
        android:textColor="#2C5282"
        android:textSize="14sp"
        android:gravity="center"
        android:background="#F0F4F8" />

</LinearLayout>