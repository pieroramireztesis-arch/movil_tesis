<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <!-- Icono redondo izquierda -->
    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle_outline"
        android:padding="6dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_play_circle"
            app:tint="@color/ai_primary" />
    </FrameLayout>

    <!-- Texto -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTituloMaterial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Título del recurso"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="@color/ai_text_dark"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvDescripcionMaterial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Video didáctico · Duración aprox.: 10 min"
            android:textSize="13sp"
            android:textColor="@color/ai_text_muted"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Ícono de menú / arrastre derecha -->
    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_menu_24"
        app:tint="@color/ai_text_muted" />

</LinearLayout>
