<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ai_bg_screen">

    <!-- Páginas deslizables -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/onboardingPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Botón Saltar (esquina superior derecha) -->
    <TextView
        android:id="@+id/tvOnboardingSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:paddingTop="52dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:text="Saltar"
        android:textColor="#CCFFFFFF"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"/>

    <!-- Controles inferiores: dots + botón -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingBottom="48dp">

        <!-- Indicadores de página (dots) -->
        <LinearLayout
            android:id="@+id/dotsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp"/>

        <!-- Botón Siguiente / Comenzar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOnboardingNext"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Siguiente"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            app:backgroundTint="#818CF8"
            app:cornerRadius="16dp"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>

</FrameLayout>