<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_gradient_header">

    <!-- Orbe decorativo derecha -->
    <View
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:background="@drawable/bg_orb_white"
        android:layout_gravity="top|end"
        android:layout_marginTop="-20dp"
        android:layout_marginEnd="-20dp"/>

    <!-- Símbolos matemáticos decorativos flotantes -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="∑"
        android:textColor="#55FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="56dp"
        android:layout_marginBottom="2dp"
        android:importantForAccessibility="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="π"
        android:textColor="#48FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="6dp"
        android:importantForAccessibility="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="x²"
        android:textColor="#50FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="110dp"
        android:layout_marginBottom="8dp"
        android:importantForAccessibility="no"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="∫"
        android:textColor="#45FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="8dp"
        android:importantForAccessibility="no"/>

    <!-- Contenido -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_l"
        android:paddingEnd="@dimen/spacing_l"
        android:paddingTop="@dimen/spacing_m"
        android:paddingBottom="@dimen/spacing_m">

        <ImageView
            android:id="@+id/imgBrandLogo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/logo_colegio"
            android:contentDescription="Logo I.E. 27 de Diciembre"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_m"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tutor Math"
                android:textAppearance="@style/TextAppearance.TutorMath.Subtitle"
                android:textColor="@color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="I.E. 27 de Diciembre · Lambayeque"
                android:textAppearance="@style/TextAppearance.TutorMath.Label"
                android:textColor="#CCFFFFFF"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>